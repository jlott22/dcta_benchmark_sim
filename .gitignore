# Python bytecode and interpreter caches
__pycache__/
*.py[cod]
*$py.class

# Test, type-checker, and coverage caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# Local virtual environments
.venv/
venv/
env/

# Editor and operating-system metadata
.idea/
.vscode/
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
*.log
*~

# Generated figures and image artifacts
*.fig
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.tif
*.tiff
*.webp
*.svg
*.eps

# Transient study execution state (preserve result CSV/JSON and manifests)
/runs/**/logs/
/runs/**/parts/
/runs/**/archive/
/runs/**/launcher.pid
/runs/**/monitor_progress.py
/runs/**/start_all_*.sh
/runs/**/_trial_journal.jsonl
/runs/**/_FAILED.txt
/runs/**/_COMPLETE.txt
